{
  // General UI --------------------------------------------------------------------------------------------------------
    "window.menuBarVisibility": "toggle",
    "window.zoomLevel": 2,
    "workbench.activityBar.visible": false,
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.value": 1,
    "workbench.editor.limit.perEditorGroup": true,
    "workbench.startupEditor": "newUntitledFile",
    "workbench.editor.showTabs": false,
    "workbench.tree.indent": 20,
    "workbench.localHistory.mergeWindow": 30,
    "workbench.colorTheme": "Nord",
    "workbench.colorCustomizations": {
      "editor.lineHighlightBorder": "#ffffff08",
      "editorCursor.foreground": "#ff0000",
      "editorWhitespace.foreground": "#5c5c5c78"
    },
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,

  // Editor ------------------------------------------------------------------------------------------------------------
    "editor.suggest.showWords": false,
    "editor.inlayHints.enabled": false,
    "editor.suggestSelection": "first",
    "editor.fontFamily": "JetBrainsMono Nerd Font",
    "editor.insertSpaces": true,
    "editor.quickSuggestions": false,
    "editor.fontLigatures": true,
    "editor.renderWhitespace": "all",
    "editor.cursorBlinking": "solid",
    "editor.wordWrap": "off",
    "editor.minimap.renderCharacters": false,
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.glyphMargin": true,
    "editor.lineNumbers": "off",
    "editor.tabSize": 4,
    "editor.rulers": [120],
    "editor.accessibilitySupport": "off",
    "editor.lineHeight": 19,
    "editor.fontSize": 13,
    "editor.minimap.enabled": false,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "debug.javascript.autoAttachFilter": "disabled",
    "debug.allowBreakpointsEverywhere": true,
    "editor.folding": false,

  // Terminal ----------------------------------------------------------------------------------------------------------
    "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.enablePersistentSessions": false,
    "terminal.integrated.localEchoLatencyThreshold": -1,
    "terminal.integrated.defaultProfile.linux": "fish",
    "terminal.integrated.minimumContrastRatio": 1,

  // Code formatting and languages -------------------------------------------------------------------------------------
    "[html]": {
      "editor.tabSize": 2
    },
    "[json]": {
      "editor.tabSize": 2
    },
    "[md]": {
      "editor.wordWrap": "on"
    },
    "typescript.tsserver.log": "off",
    "typescript.updateImportsOnFileMove.enabled": "always",
    "javascript.updateImportsOnFileMove.enabled": "always",
    "files.eol": "\n",

  // VIM ---------------------------------------------------------------------------------------------------------------
    "vim.surround": true,
    "vim.easymotion": true,
    "vim.camelCaseMotion.enable": false, // disabled due to use of whichkey

    "vim.easymotionKeys": "hklyuiopnmqwertzxcvbasdgjf",
    "vim.easymotionMarkerBackgroundColor": "#00000000",
    "vim.easymotionMarkerForegroundColorOneChar": "Red",
    "vim.easymotionMarkerForegroundColorTwoCharFirst": "Orange",
    "vim.easymotionMarkerForegroundColorTwoCharSecond": "Orange",

    "vim.useSystemClipboard": true,
    "vim.useCtrlKeys": false,
    "vim.insertModeKeyBindings": [
      {
        "before": ["e", "u"],
        "after": ["<esc>"]
      }
    ],
    "vim.normalModeKeyBindingsNonRecursive": [
      {
        "before": ["s"],
        "after": ["leader", "leader", "s"]
      },
      {
        "before": ["j"],
        "after": ["g", "j"]
      },
      {
        "before": ["k"],
        "after": ["g", "k"]
      },
      {
        "before": ["g", "p"],
        "after": ["`", "[", "v", "`", "]"]
      },
      {
        "before": ["<"],
        "commands": ["editor.action.outdentLines"]
      },
      {
        "before": [">"],
        "commands": ["editor.action.indentLines"]
      },
      {
        "before": ["<space>"],
        "commands": ["whichkey.show"]
      }
    ],
    "vim.visualModeKeyBindingsNonRecursive": [
      {
        "before": ["v"],
        "after": ["<esc>"]
      },
      {
        "before": ["s"],
        "after": ["leader", "leader", "s"]
      },
      {
        "before": ["<"],
        "commands": ["editor.action.outdentLines"]
      },
      {
        "before": [">"],
        "commands": ["editor.action.indentLines"]
      },
      {
        "before": ["<space>"],
        "commands": ["whichkey.show"]
      }
    ],

  // Whichkey ----------------------------------------------------------------------------------------------------------
    "whichkey.sortOrder": "none",
    "whichkey.bindings": [
      {
        "key": "u",
        "name": "$(book) User interface...",
        "type": "bindings",
        "bindings": [
          {
            "key": "e",
            "name": "$(explorer-view-icon) Explorer",
            "type": "command",
            "command": "workbench.view.explorer"
          },
          {
            "key": "x",
            "name": "$(extensions-view-icon) Extensions",
            "type": "command",
            "command": "workbench.view.extensions"
          },
          {
            "key": "d",
            "name": "$(debug-alt) Debugger",
            "type": "command",
            "command": "workbench.view.debug"
          },
          {
            "key": "g",
            "name": "$(source-control-view-icon) Git",
            "type": "command",
            "command": "workbench.scm.focus"
          },
          {
            "key": "t",
            "name": "$(test-view-icon) Tests",
            "type": "command",
            "command": "workbench.view.testing.focus"
          },
          {
            "key": "o",
            "name": "$(outline-view-icon) Outline",
            "type": "command",
            "command": "outline.focus"
          },
          {
            "key": "f",
            "name": "$(fullscreen) Fullscreen",
            "type": "command",
            "command": "workbench.action.toggleFullScreen",
          },
          {
            "key": "z",
            "name": "$(rocket) Zen mode",
            "type": "command",
            "command": "workbench.action.toggleZenMode",
          },
          {
            "key": "m",
            "name": "$(markdown) Markdown preview",
            "type": "command",
            "command": "markdown.showPreview",
            "when": "!notebookEditorFocused && editorLangId == 'markdown'"
          }
        ]
      },
      {
        "key": "a",
        "name": "$(lightbulb) Code actions...",
        "type": "bindings",
        "bindings": [
          {
            "key": "r",
            "name": "$(replace) Rename",
            "type": "command",
            "command": "editor.action.rename",
            "when": "editorHasRenameProvider && editorTextFocus && !editorReadonly",
          },
          {
            "key": "q",
            "name": "$(lightbulb-autofix) Quick Fix",
            "type": "command",
            "command": "editor.action.quickFix"
          },
          {
            "key": "h",
            "name": "$(info) Hover Info",
            "type": "command",
            "command": "editor.action.showHover"
          }
        ]
      },
      {
        "key": "w",
        "name": "$(window) Window...",
        "type": "bindings",
        "bindings": [
          {
            "key": "s",
            "name": "$(split-horizontal) Split horizontal",
            "type": "command",
            "command": "workbench.action.splitEditorRight"
          },
          {
            "key": "S",
            "name": "$(split-vertical) Split vertical",
            "type": "command",
            "command": "workbench.action.splitEditorDown"
          },
          {
            "key": "h",
            "name": "$(triangle-left) Focus on left group",
            "type": "command",
            "command": "workbench.action.focusLeftGroup"
          },
          {
            "key": "j",
            "name": "$(triangle-down) Focus on bottom group",
            "type": "command",
            "command": "workbench.action.focusBelowGroup"
          },
          {
            "key": "k",
            "name": "$(triangle-up) Focus on top group",
            "type": "command",
            "command": "workbench.action.focusAboveGroup"
          },
          {
            "key": "l",
            "name": "$(triangle-right) Focus on right group",
            "type": "command",
            "command": "workbench.action.focusRightGroup"
          },
          {
            "key": "m",
            "name": "$(move) Move editor...",
            "type": "bindings",
            "bindings": [
              {
                "key": "h",
                "name": "$(triangle-left) Move editor left",
                "type": "command",
                "command": "workbench.action.moveActiveEditorGroupLeft"
              },
              {
                "key": "j",
                "name": "$(triangle-down) Move editor down",
                "type": "command",
                "command": "workbench.action.moveActiveEditorGroupDown"
              },
              {
                "key": "k",
                "name": "$(triangle-up) Move editor up",
                "type": "command",
                "command": "workbench.action.moveActiveEditorGroupUp"
              },
              {
                "key": "l",
                "name": "$(triangle-right) Move editor right",
                "type": "command",
                "command": "workbench.action.moveActiveEditorGroupRight"
              }
            ]
          }
        ]
      },
      {
        "key": "d",
        "name": "$(debug-alt) Debugger...",
        "type": "bindings",
        "bindings": [
          {
            "key": "b",
            "name": "$(debug-breakpoint) Breakpoint",
            "type": "command",
            "command": "editor.debug.action.toggleBreakpoint"
          },
          {
            "key": "B",
            "name": "$(activate-breakpoints) Breakpoints...",
            "type": "bindings",
            "bindings": [
              {
                "key": "b",
                "name": "$(debug-breakpoint) Breakpoint",
                "type": "command",
                "command": "editor.debug.action.toggleBreakpoint"
              },
              {
                "key": "c",
                "name": "$(debug-breakpoint-function) Conditional Breakpoint",
                "type": "command",
                "command": "editor.debug.action.conditionalBreakpoint"
              },
              {
                "key": "l",
                "name": "$(debug-breakpoint-log) Log Point",
                "type": "command",
                "command": "editor.debug.action.addLogPoint"
              }
            ]
          },
          {
            "key": "h",
            "name": "$(info) Hover Info",
            "type": "command",
            "command": "editor.debug.action.showDebugHover"
          }
        ]
      },
      {
        "key": "g",
        "name": "$(source-control) Git...",
        "type": "bindings",
        "bindings": [
          {
            "key": "r",
            "name": "$(discard) Revert selected",
            "type": "command",
            "command": "git.revertSelectedRanges",
            "when": "isInDiffEditor"
          },
          {
            "key": "s",
            "name": "$(diff-added) Stage selected",
            "type": "command",
            "command": "git.stageSelectedRanges",
            "when": "isInDiffEditor"
          },
          {
            "key": "S",
            "name": "$(diff-removed) Unstage selected",
            "type": "command",
            "command": "git.unstageSelectedRanges",
            "when": "isInDiffEditor"
          },
        ],
      },
      {
        "key": " ",
        "name": "$(arrow-both) Navigate to...",
        "type": "bindings",
        "bindings": [
          {
            "key": "t",
            "name": "$(test-view-icon) Go to spec/implementation",
            "type": "command",
            "command": "extension.goToSpec"
          },
          {
            "key": "o",
            "name": "$(link) Open link",
            "type": "command",
            "command": "editor.action.openLink"
          },
          {
            "key": "r",
            "name": "$(references) Go to references",
            "type": "command",
            "command": "editor.action.referenceSearch.trigger"
          },
          {
            "key": "d",
            "name": "$(symbol-interface) Go to definition",
            "type": "command",
            "command": "editor.action.revealDefinition"
          },
          {
            "key": "s",
            "name": "$(symbol-function) Go to symbol",
            "type": "command",
            "command": "workbench.action.gotoSymbol",
          },
          {
            "key": "b",
            "name": "$(history) Go back",
            "type": "command",
            "command": "workbench.action.navigateBack",
          }
        ]
      },
      {
        "key": "c",
        "name": "$(symbol-parameter) Comment",
        "type": "command",
        "command": "editor.action.commentLine"
      },
      {
        "key": "f",
        "name": "$(file) Open file",
        "type": "command",
        "command": "workbench.action.files.openFile",
      },
      {
        "key": "F",
        "name": "$(file-directory) Open folder",
        "type": "command",
        "command": "workbench.action.files.openFolder",
      }
    ],
  
  // Misc---------------------------------------------------------------------------------------------------------------
    "files.autoSave": "afterDelay",
    "timeline.excludeSources": [],
    "telemetry.telemetryLevel": "off",
    "security.workspace.trust.untrustedFiles": "open",
    "extensions.autoUpdate": false,
    "extensions.ignoreRecommendations": true,
    "testing.automaticallyOpenPeekViewDuringAutoRun": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "cSpell.language": "en,ru-RU",
    "livePreview.notifyOnOpenLooseFile": false,
    "update.mode": "manual",
    "terminal.integrated.enableMultiLinePasteWarning": false,
}
